{% sw_extends '@Storefront/storefront/component/product/card/box-standard.html.twig' %}

{% block component_product_box %}
    {{ parent() }}

    {% if s4gtmConfig is defined and s4gtmConfig.operational and s4gtmConfig.dataLayerEnabled
        and product is defined and product is not null %}
        <data class="s4gtm-product-data" hidden data-s4gtm-item="{{ s4gtm_item_json(product) }}"></data>
    {% endif %}
{% endblock %}
